# Server Environment
NODE_ENV=production
PORT=3001

# Security - JWT Secret (generate a strong random string!)
JWT_SECRET=your-strong-random-secret-key-here-minimum-32-characters

# Frontend URL for CORS
FRONTEND_URL=https://your-domain.com

# Optional: Database path (default: ./data/app.db)
# DB_PATH=/app/data/app.db

# Optional: Tencent Cloud COS (file storage)
# TENCENT_COS_SECRET_ID=your-secret-id
# TENCENT_COS_SECRET_KEY=your-secret-key
# TENCENT_COS_BUCKET=your-bucket-name
# TENCENT_COS_REGION=ap-guangzhou
# TENCENT_COS_DOMAIN=your-cdn-domain.com
